# Agents module: build binaries and images. From repo root: just agents/build-dev
# shellcheck disable=SC2148,SC1007
set shell := ["bash", "-euo", "pipefail", "-c"]

root_dir := justfile_directory() / ".."

_build_prod name pkg_path out_dir:
    #!/usr/bin/env bash
    set -e
    root="$(cd "{{ root_dir }}" && pwd)"
    mkdir -p "$root/{{ out_dir }}"
    pushd "$root" >/dev/null
    trap 'popd >/dev/null 2>/dev/null || true' EXIT
    CGO_ENABLED=0 GOEXPERIMENT=runtimesecret go build -ldflags="-s -w" -o "$root/{{ out_dir }}/{{ name }}" {{ pkg_path }}
    command -v upx >/dev/null 2>&1 && upx --best "$root/{{ out_dir }}/{{ name }}" || true
    echo "Built: $root/{{ out_dir }}/{{ name }}"

_build_dev name pkg_path out_dir:
    #!/usr/bin/env bash
    set -e
    root="$(cd "{{ root_dir }}" && pwd)"
    mkdir -p "$root/{{ out_dir }}"
    pushd "$root" >/dev/null
    trap 'popd >/dev/null 2>/dev/null || true' EXIT
    GOEXPERIMENT=runtimesecret go build -gcflags="all=-N -l" -o "$root/{{ out_dir }}/{{ name }}-dev" {{ pkg_path }}
    echo "Built: $root/{{ out_dir }}/{{ name }}-dev"

_build_container containerfile tag *ARGS:
    #!/usr/bin/env bash
    set -e
    root="$(cd "{{ root_dir }}" && pwd)"
    pushd "$root" >/dev/null
    trap 'popd >/dev/null 2>/dev/null || true' EXIT
    if command -v podman >/dev/null 2>&1; then
      podman build -f "{{ containerfile }}" -t "{{ tag }}" {{ ARGS }} .
    else
      docker build -f "{{ containerfile }}" -t "{{ tag }}" {{ ARGS }} .
    fi

install-go:
    @just --justfile "{{ root_dir }}/justfile" --working-directory "{{ root_dir }}" install-go

build: install-go
    @just build-cynode-pma build-cynode-sba
build-dev: install-go
    @just build-cynode-pma-dev build-cynode-sba-dev

build-cynode-pma: install-go
    @just _build_prod cynode-pma ./agents/cmd/cynode-pma agents/bin
build-cynode-pma-dev: install-go
    @just _build_dev cynode-pma ./agents/cmd/cynode-pma agents/bin
build-cynode-sba: install-go
    @just _build_prod cynode-sba ./agents/cmd/cynode-sba agents/bin
build-cynode-sba-dev: install-go
    @just _build_dev cynode-sba ./agents/cmd/cynode-sba agents/bin

build-cynode-pma-image *ARGS:
    @just _build_container agents/cmd/cynode-pma/Containerfile cynodeai-cynode-pma:dev {{ ARGS }}
build-cynode-sba-image *ARGS:
    @just _build_container agents/cmd/cynode-sba/Containerfile cynodeai-cynode-sba:dev {{ ARGS }}
