# Example local development environment (copy to `.env.dev` and adjust; `.env*` is gitignored).
# Scripts such as `scripts/ensure_env_dev.sh` may create `.env.dev` with a generated secure-store key.

# --- Worker secure store (32 bytes, base64) — generated automatically on first setup if missing ---
# CYNODE_SECURE_STORE_MASTER_KEY_B64=

# --- NATS dev nkey seeds (no defaults in the binary; set all four, or provide NATS_DEV_SEEDS_FILE, or omit to auto-generate once under XDG cache) ---
# NATS_DEV_OPERATOR_SEED=
# NATS_DEV_SYSTEM_ACCOUNT_SEED=
# NATS_DEV_ACCOUNT_SEED=
# NATS_DEV_SIGNING_SEED=
# NATS_DEV_SEEDS_FILE=

# --- Orchestrator NATS issuer (optional; in DevMode filled from LoadDevSeeds when unset) ---
# NATS_ACCOUNT_SEED=
# NATS_ACCOUNT_SIGNING_SEED=

# --- Common stack defaults (compose / just often set these; listed for reference) ---
# JWT_SECRET=
# NODE_REGISTRATION_PSK=
# NODE_PSK=
# BOOTSTRAP_ADMIN_PASSWORD=
# ADMIN_PASSWORD=
# WORKER_API_BEARER_TOKEN=
