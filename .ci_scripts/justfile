lint-containerfiles:
    #!/usr/bin/env bash
    set -e
    root="$(cd "{{ root_dir }}" && pwd)"
    pushd "$root" >/dev/null
    trap 'popd >/dev/null 2>/dev/null || true' EXIT
    files=()
    while IFS= read -r -d '' p; do files+=("$p"); done < <(find . -type f \( -name 'Containerfile*' -o -name 'Dockerfile*' \) ! -path '*/.git/*' -print0 | sort -z)
    if [ ${#files[@]} -eq 0 ]; then
      echo "No Containerfile/Dockerfile found."
      exit 0
    fi
    for f in "${files[@]}"; do
        [ -f "$root/$f" ] || { echo "Missing $f"; exit 1; }
        echo "==> hadolint $f"
        if command -v hadolint >/dev/null 2>&1; then
          hadolint "$root/$f"
        elif command -v podman >/dev/null 2>&1; then
          podman run --rm -v "$root:/lint:ro" -w /lint hadolint/hadolint:latest-alpine hadolint "/lint/$f"
        elif command -v docker >/dev/null 2>&1; then
          docker run --rm -v "$root:/lint:ro" -w /lint hadolint/hadolint:latest-alpine hadolint "/lint/$f"
        else
          echo "hadolint not found; install hadolint or podman/docker for container fallback" >&2
          exit 1
        fi
    done
    echo "Containerfile lint: OK"

lint-md *PATHS:
    #!/usr/bin/env bash
    set -e
    root="$(cd "{{ root_dir }}" && pwd)"
    pushd "$root" >/dev/null
    trap 'popd >/dev/null 2>/dev/null || true' EXIT
    if [ -z "{{ PATHS }}" ]; then markdownlint-cli2 --fix '**/*.md'; else markdownlint-cli2 --fix {{ PATHS }}; fi

go-fmt: install-go
    #!/usr/bin/env bash
    set -e
    root="$(cd "{{ root_dir }}" && pwd)"
    go_modules=$(grep -E '^[[:space:]]*\./' "$root/go.work" | sed 's|^[[:space:]]*\./||;s/[[:space:]].*//' | tr '\n' ' ')
    for m in $go_modules; do
      echo "==> gofmt -s -w ($m)"; (pushd "$root/$m" >/dev/null && gofmt -s -w .)
      echo "==> go mod tidy ($m)"; (pushd "$root/$m" >/dev/null && go mod tidy)
    done

lint-python paths="scripts,.ci_scripts":
    #!/usr/bin/env bash
    set +e
    root="$(cd "{{ root_dir }}" && pwd)"
    pushd "$root" >/dev/null
    trap 'popd >/dev/null 2>/dev/null || true' EXIT
    LINT_PATHS=$(echo "{{ paths }}" | tr ',' ' ')
    command -v python3 >/dev/null 2>&1 || { echo "Error: python3 not found."; exit 1; }
    need() { command -v "$1" >/dev/null 2>&1 || [ -x .venv/bin/"$1" ] || { echo "Error: $1 not found. Run 'just venv'"; exit 1; }; }
    need flake8; need pylint; need radon; need xenon; need vulture; need bandit
    [ -d .venv ] && export PATH="$PWD/.venv/bin:$PATH"
    export PYTHONPATH="$PWD/scripts"
    echo "Running flake8..."; flake8 $LINT_PATHS --jobs=1; FLAKE8_RESULT=$?
    echo "Running pylint..."; pylint --rcfile=.pylintrc $LINT_PATHS; PYLINT_RESULT=$?
    radon cc -s -a $LINT_PATHS || true
    xenon -b C $LINT_PATHS; XENON_RESULT=$?
    radon mi -s $LINT_PATHS || true
    TMP_MI=$(mktemp); radon mi -j $LINT_PATHS -O "$TMP_MI"
    python3 -c "import sys, json; d=json.load(open(sys.argv[1])); bad=[k for k,v in d.items() if v.get('rank')=='C']; [print('MI rank C:', f) for f in bad]; sys.exit(1 if bad else 0)" "$TMP_MI"; MI_RESULT=$?
    rm -f "$TMP_MI"
    vulture $LINT_PATHS --min-confidence 80 || true
    bandit -r $LINT_PATHS -c bandit.yaml; BANDIT_RESULT=$?
    echo "Lint exit codes: flake8=$FLAKE8_RESULT pylint=$PYLINT_RESULT xenon=$XENON_RESULT radon_mi=$MI_RESULT bandit=$BANDIT_RESULT"
    if [ "$FLAKE8_RESULT" -ne 0 ] || [ "$PYLINT_RESULT" -ne 0 ] || [ "$XENON_RESULT" -ne 0 ] || [ "$MI_RESULT" -ne 0 ] || [ "$BANDIT_RESULT" -ne 0 ]; then
      exit 1
    fi
    exit 0
