# Dev build (skip UPX): add --build-arg SKIP_UPX=1 for faster iteration.
FROM golang:1.26-alpine AS build
ARG SKIP_UPX=0

WORKDIR /src
RUN apk add --no-cache ca-certificates git && ( [ "$SKIP_UPX" = "1" ] || apk add --no-cache upx )

ENV CGO_ENABLED=0

COPY . .

RUN go build -ldflags="-s -w" -o /out/control-plane ./orchestrator/cmd/control-plane \
    && ( [ "$SKIP_UPX" = "1" ] || upx --best /out/control-plane )

FROM alpine:3.20
RUN apk add --no-cache ca-certificates

WORKDIR /app
COPY --from=build /out/control-plane /app/control-plane
COPY orchestrator/migrations /app/migrations

ENV MIGRATIONS_DIR=/app/migrations

EXPOSE 8082
ENTRYPOINT ["/app/control-plane"]
