# Dev build (skip UPX): add --build-arg SKIP_UPX=1 for faster iteration.
FROM golang:1.26-alpine AS build
ARG SKIP_UPX=0

WORKDIR /src
RUN apk add --no-cache ca-certificates git && ( [ "$SKIP_UPX" = "1" ] || apk add --no-cache upx )

ENV CGO_ENABLED=0

COPY . .

RUN go build -ldflags="-s -w" -o /out/user-gateway ./orchestrator/cmd/user-gateway \
    && ( [ "$SKIP_UPX" = "1" ] || upx --best /out/user-gateway )

FROM alpine:3.20
RUN apk add --no-cache ca-certificates

WORKDIR /app
COPY --from=build /out/user-gateway /app/user-gateway

EXPOSE 8080
ENTRYPOINT ["/app/user-gateway"]
