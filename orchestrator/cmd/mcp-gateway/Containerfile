# Dev build (skip UPX): add --build-arg SKIP_UPX=1 for faster iteration.
FROM golang:1.26-alpine AS build
ARG SKIP_UPX=0

WORKDIR /src
RUN apk add --no-cache ca-certificates git && ( [ "$SKIP_UPX" = "1" ] || apk add --no-cache upx )

ENV CGO_ENABLED=0

COPY . .

RUN go build -ldflags="-s -w" -o /out/mcp-gateway ./orchestrator/cmd/mcp-gateway \
    && ( [ "$SKIP_UPX" = "1" ] || upx --best /out/mcp-gateway )

FROM alpine:3.20
RUN apk add --no-cache ca-certificates

WORKDIR /app
COPY --from=build /out/mcp-gateway /app/mcp-gateway

EXPOSE 8083
ENTRYPOINT ["/app/mcp-gateway"]
