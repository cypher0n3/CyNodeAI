FROM golang:1.26-alpine AS build

WORKDIR /src
RUN apk add --no-cache ca-certificates git upx

ENV CGO_ENABLED=0
ENV GOEXPERIMENT=secret

COPY . .

RUN go build -ldflags="-s -w" -o /out/cynodeai-wnm ./worker_node/cmd/node-manager \
    && upx --best /out/cynodeai-wnm

FROM alpine:3.20
RUN apk add --no-cache ca-certificates

WORKDIR /app
COPY --from=build /out/cynodeai-wnm /app/cynodeai-wnm

ENTRYPOINT ["/app/cynodeai-wnm"]
